fun paymentChecks(price: Dec, budget: Dec) -> Void:
  show(price == budget);
  show(price != budget);
  show(price < budget);
  show(price <= budget);
  show(price > budget);
  show(price >= budget);
  show((price < budget) and true);
  show((price > budget) or true);
  show(not false);
  return;
end

show(3 == 5);
show(3 != 5);
show(3 < 5);
show(3 <= 5);
show(3 > 5);
show(3 >= 5);
show((3 < 5) and true);
show((3 > 5) or true);
show(not false);

// Equality, comparisons, and/or, not